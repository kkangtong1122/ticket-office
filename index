<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
<title>🎟 매표소</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Nanum+Gothic:wght@400;700&family=Nanum+Myeongjo:wght@400;700&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Bebas+Neue&family=DM+Mono:wght@400;500&family=Noto+Serif+KR:wght@700&display=swap');
@font-face{font-family:'Ridibatang';src:url('https://cdn.jsdelivr.net/gh/projectnoonnu/noonfonts_twelve@1.0/RIDIBatang.woff') format('woff');font-display:swap;}
@font-face{font-family:'GangwonEduModu';src:url('https://cdn.jsdelivr.net/gh/projectnoonnu/noonfonts_2201-2@1.0/GangwonEdu_OTFLightA.woff') format('woff');font-weight:300;font-display:swap;}
@font-face{font-family:'GangwonEduModu';src:url('https://cdn.jsdelivr.net/gh/projectnoonnu/noonfonts_2201-2@1.0/GangwonEdu_OTFBoldA.woff') format('woff');font-weight:700;font-display:swap;}
@font-face{font-family:'OngleipParkDahyeon';src:url('https://cdn.jsdelivr.net/gh/projectnoonnu/2411-3@1.0/Ownglyph_ParkDaHyun.woff2') format('woff2');font-display:swap;}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{--bg:#eae6de;--pn:#fff;--bd:#ddd8cf;--tx:#1a1714;--mt:#8a847a;--ac:#c05020;--ui:'Noto Sans KR',sans-serif;--ckA:#e8e4dc;--ckB:#f2efea;}
body{font-family:var(--ui);background:var(--bg);color:var(--tx);}
body.dark{--bg:#1a1a1e;--pn:#252528;--bd:#3a3a40;--tx:#e0e0e4;--mt:#8a8a94;--ac:#e06030;}
body.dark input,body.dark textarea,body.dark select{background:#2a2a30;color:#e0e0e4;border-color:#3a3a40;}
body.dark .tb{background:#202024;}body.dark .pvh{background:#202024;}
body.dark .sg button,body.dark .ec,body.dark .ip,body.dark .btc,body.dark .fd button{background:#2a2a30;color:var(--mt);}
.app{display:flex;height:100vh;}
.panel{width:330px;flex-shrink:0;background:var(--pn);border-right:1px solid var(--bd);display:flex;flex-direction:column;overflow:hidden;}
.preview{flex:1;display:flex;flex-direction:column;overflow:hidden;}
@media(max-width:700px){.app{flex-direction:column;height:auto;min-height:100vh;}.preview{flex:none;height:45vh;min-height:200px;order:-1;}.panel{width:100%;flex:1;border-right:none;border-top:1px solid var(--bd);}}
.tb{display:flex;border-bottom:1px solid var(--bd);background:#f8f6f2;flex-shrink:0;}
.tb button{flex:1;padding:.45rem 0;font-family:var(--ui);font-size:.66rem;font-weight:500;border:none;background:none;color:var(--mt);cursor:pointer;border-bottom:2px solid transparent;transition:.12s;}
.tb button.on{color:var(--ac);border-bottom-color:var(--ac);}
.tp{flex:1;overflow-y:auto;padding:.7rem;-webkit-overflow-scrolling:touch;}
.tp::-webkit-scrollbar{width:3px;}.tp::-webkit-scrollbar-thumb{background:var(--bd);border-radius:2px;}
.pg{display:none;}.pg.on{display:flex;flex-direction:column;gap:.6rem;}
.sc{font-size:.56rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--mt);margin-bottom:.08rem;}
.f{display:flex;flex-direction:column;gap:.1rem;}.f>label{font-size:.68rem;color:var(--mt);}
.rw{display:flex;gap:4px;align-items:flex-end;}.rw>*{flex:1;}
input[type=text],input[type=number],textarea,select{width:100%;font-family:var(--ui);font-size:.72rem;border:1px solid var(--bd);border-radius:4px;padding:.28rem .4rem;background:#faf9f7;color:var(--tx);}
input:focus,textarea:focus,select:focus{outline:none;border-color:var(--ac);}
textarea{resize:vertical;min-height:32px;line-height:1.3;}
input[type=number]{width:48px;text-align:center;padding:.28rem .1rem;}
input[type=range]{width:100%;accent-color:var(--ac);height:16px;}
input[type=color]{width:24px;height:20px;border:1px solid var(--bd);border-radius:3px;padding:1px;cursor:pointer;background:#faf9f7;}
.cr{display:flex;align-items:center;gap:.3rem;}.cr span{font-size:.68rem;color:var(--mt);flex:1;}
.sg{display:flex;gap:2px;flex-wrap:wrap;}
.sg button{flex:1;font-family:var(--ui);font-size:.62rem;padding:.24rem .06rem;border:1px solid var(--bd);border-radius:4px;background:#faf9f7;color:var(--mt);cursor:pointer;transition:.1s;white-space:nowrap;min-width:0;}
.sg button.on{background:var(--tx);border-color:var(--tx);color:#fff;}
.ms button.on{background:var(--ac);border-color:var(--ac);color:#fff;}
.sr{display:flex;gap:2px;}
.sb2{font-family:var(--ui);font-size:.68rem;width:22px;height:20px;border:1px solid var(--bd);border-radius:3px;background:#faf9f7;color:var(--mt);cursor:pointer;}.sb2.on{background:var(--tx);border-color:var(--tx);color:#fff;}
.sb2.fb{font-weight:700;}.sb2.fi{font-style:italic;}.sb2.fu{text-decoration:underline;}.sb2.fs{text-decoration:line-through;}
.tg{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;}
.tc{cursor:pointer;border-radius:4px;padding:2px;font-size:.54rem;font-weight:500;border:2px solid transparent;text-align:center;line-height:1.1;}.tc.on{border-color:var(--ac);}
.eg{display:grid;grid-template-columns:repeat(5,1fr);gap:2px;}
.ec{cursor:pointer;border:1.5px solid var(--bd);border-radius:4px;padding:1px;display:flex;flex-direction:column;align-items:center;gap:0;transition:.1s;background:#faf9f7;}
.ec:hover{border-color:var(--mt);}.ec.on{border-color:var(--ac);background:#fef6f2;}
.ec span{font-size:.46rem;color:var(--mt);line-height:1;}.ec.on span{color:var(--ac);}
.ipg{display:grid;grid-template-columns:repeat(5,1fr);gap:2px;}
.ip{cursor:pointer;border:1.5px solid var(--bd);border-radius:3px;padding:1px;display:flex;flex-direction:column;align-items:center;gap:0;transition:.1s;background:#faf9f7;}
.ip:hover{border-color:var(--mt);}.ip.on{border-color:var(--ac);background:#fef6f2;}
.ip span{font-size:.44rem;color:var(--mt);}.ip.on span{color:var(--ac);}
.iu{border:1.5px dashed var(--bd);border-radius:5px;padding:.25rem;text-align:center;font-size:.66rem;color:var(--mt);cursor:pointer;position:relative;}
.iu:hover{border-color:var(--ac);color:var(--ac);}.iu input{position:absolute;inset:0;opacity:0;cursor:pointer;}
.iv{width:100%;height:40px;object-fit:cover;border-radius:3px;display:none;margin-top:2px;}
.ic{display:none;width:100%;font-family:var(--ui);font-size:.58rem;padding:.12rem;background:none;border:1px solid var(--bd);border-radius:3px;color:var(--mt);cursor:pointer;margin-top:2px;}
.tog{display:flex;align-items:center;gap:4px;cursor:pointer;font-size:.68rem;color:var(--mt);user-select:none;}
.tog input{display:none;}.tog .t{width:26px;height:14px;border-radius:7px;background:var(--bd);position:relative;transition:.15s;flex-shrink:0;}
.tog input:checked+.t{background:var(--ac);}.tog .t::after{content:'';position:absolute;top:1.5px;left:1.5px;width:11px;height:11px;border-radius:50%;background:#fff;transition:.15s;}
.tog input:checked+.t::after{left:13.5px;}
.fr{display:flex;gap:3px;align-items:flex-end;}.fr>.f{flex:1;}.fr>.sz{width:44px;flex-shrink:0;}
.dv{border:none;border-top:1px solid var(--bd);margin:.08rem 0;}
.btg{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;}
.btc{cursor:pointer;border:1.5px solid var(--bd);border-radius:4px;padding:2px;text-align:center;font-size:.52rem;color:var(--mt);transition:.1s;background:#faf9f7;}
.btc:hover{border-color:var(--mt);}.btc.on{border-color:var(--ac);background:#fef6f2;color:var(--ac);}
.pvh{display:flex;align-items:center;justify-content:space-between;padding:.35rem .5rem;border-bottom:1px solid var(--bd);background:#f8f6f2;flex-shrink:0;flex-wrap:wrap;gap:3px;}
.pvt{display:flex;gap:3px;}.pt{font-family:var(--ui);font-size:.66rem;font-weight:500;padding:.25rem .55rem;border:1px solid var(--bd);border-radius:12px;background:var(--pn);color:var(--mt);cursor:pointer;}.pt.on{background:var(--tx);border-color:var(--tx);color:#fff;}
.pa{display:flex;gap:2px;flex-wrap:wrap;}
.pb{font-family:var(--ui);font-size:.58rem;font-weight:500;padding:.18rem .35rem;border:1px solid var(--bd);border-radius:4px;background:var(--pn);color:var(--mt);cursor:pointer;transition:.1s;}
.pb:hover{background:var(--tx);color:#fff;border-color:var(--tx);}.pb.pr{background:var(--tx);color:#fff;border-color:var(--tx);}
.pc{flex:1;display:flex;align-items:center;justify-content:center;padding:1rem;overflow:auto;background:repeating-conic-gradient(var(--ckA) 0% 25%,var(--ckB) 0% 50%) 0 0/16px 16px;}
.fd{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;}.fd button{font-family:var(--ui);font-size:.66rem;padding:.2rem;border:1px solid var(--bd);border-radius:3px;background:#faf9f7;color:var(--mt);cursor:pointer;}.fd button.on{background:var(--ac);border-color:var(--ac);color:#fff;}

/* ── TICKET (div-based) ── */
.ticket-outer{position:relative;display:inline-flex;filter:drop-shadow(0 4px 8px rgba(0,0,0,.15));}
.ticket-main{position:relative;overflow:hidden;}
.ticket-stub{position:relative;overflow:hidden;}
.ticket-perf{position:absolute;z-index:5;}
.ticket-strip{position:absolute;z-index:3;pointer-events:none;}
</style>
</head>
<body>
<div class="app">
<div class="panel">
<div class="tb">
<button class="on" data-t="design">🎨디자인</button>
<button data-t="front">앞면</button>
<button data-t="back">뒷면</button>
</div>
<div class="tp">

<div class="pg on" data-t="design">
<div><div class="sc">테마</div><div class="tg" id="tGrid"></div></div>
<div><div class="sc">텍스트 정렬</div>
<div class="sg" id="sgAlign">
  <button data-v="left">왼쪽</button>
  <button class="on" data-v="center">가운데</button>
  <button data-v="right">오른쪽</button>
</div></div>

<div><div class="sc">방향</div><div class="sg" id="sgO"><button class="on" data-v="landscape">가로형</button><button data-v="portrait">세로형</button></div></div>
<div><div class="sc">모서리</div><div class="eg" id="eGrid"></div></div>
<div><div class="sc">크기 (px)</div>
<div class="rw"><div class="f"><label>너비</label><input type="number" id="tW" value="500" min="200" max="900" step="10"></div><div class="f"><label>높이</label><input type="number" id="tH" value="210" min="100" max="600" step="10"></div><div class="f"><label>절취</label><input type="number" id="tS" value="130" min="40" max="250" step="5"></div></div></div>
<hr class="dv">
<div><div class="sc">색상</div>
<div class="cr"><span>배경</span><input type="color" id="cBg" value="#f5f0e0"></div>
<div class="cr"><span>강조</span><input type="color" id="cAc" value="#c8410a"></div>
<div class="cr"><span>텍스트</span><input type="color" id="cTx" value="#2a1f10"></div>
<div class="cr"><span>서브</span><input type="color" id="cSb" value="#8a6a40"></div>
<div style="margin-top:3px;">
<label class="tog"><input type="checkbox" id="bgGrad"><span class="t"></span>배경 그라데이션</label>
<div id="bgGradOpts" style="display:none;margin-top:3px;">
<div class="cr"><span>끝색상</span><input type="color" id="bgGrad2" value="#d4a830"></div>
<div class="sg" id="sgBgGDir" style="margin-top:2px;"><button class="on" data-v="135deg">↘</button><button data-v="90deg">↓</button><button data-v="0deg">→</button><button data-v="45deg">↗</button></div>
</div></div>
</div>
<hr class="dv">
<div><div class="sc">강조 띠 (복수 선택)</div>
<label class="tog"><input type="checkbox" id="stOn" checked><span class="t"></span>띠 표시</label>
<div class="sg ms" id="sgSP" style="margin-top:3px;"><button class="on" data-v="left">좌</button><button data-v="right">우</button><button data-v="top">상</button><button data-v="bottom">하</button></div>
<div class="rw" style="margin-top:3px;"><div class="f"><label>두께</label><input type="number" id="stW" value="6" min="1" max="30"></div></div></div>
