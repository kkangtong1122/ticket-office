// ✨ 텍스트 개별 오프셋 변수(fT_x, fT_y, fS_x, fS_y, fD_x, fD_y) 추가
const S={theme:'retro',orient:'landscape',edge:'straight',side:'front',fIP:'none',bIP:'none',bkTpl:'default',
