function epP(id){const W=32,H=14;if(id==='straight')return`M0,0H${W}V${H}H0Z`;if(id==='round')return`M3,0H${W-3}Q${W},0,${W},3V${H-3}Q${W},${H},${W-3},${H}H3Q0,${H},0,${H-3}V3Q0,0,3,0Z`;if(id==='roundXL')return`M7,0H${W-7}Q${W},0,${W},7V${H-7}Q${W},${H},${W-7},${H}H7Q0,${H},0,${H-7}V7Q0,0,7,0Z`;const n={waveS:4,waveL:3,zigS:5,zigL:3,scallop:4,stamp:4}[id]||4;const a={waveS:2,waveL:3,zigS:2,zigL:3,scallop:2,stamp:2}[id]||2;const s=H/n;if(id.startsWith('wave')){let d=`M0,0H${W} `;for(let i=0;i<n;i++)d+=`C${W+a},${i*s},${W+a},${(i+1)*s},${W},${(i+1)*s} `;d+=`H0 `;for(let i=n;i>0;i--)d+=`C${-a},${i*s},${-a},${(i-1)*s},0,${(i-1)*s} `;return d+'Z';}if(id.startsWith('zig')){let d=`M0,0H${W} `;for(let i=0;i<n;i++)d+=`L${W-a},${i*s+s/2}L${W},${(i+1)*s} `;d+=`H0 `;for(let i=n;i>0;i--)d+=`L${a},${(i-1)*s+s/2}L0,${(i-1)*s} `;return d+'Z';}if(id==='scallop'){let d=`M0,0H${W} `;for(let i=0;i<n;i++)d+=`A${a},${a},0,0,0,${W},${(i+1)*s} `;d+=`H0 `;for(let i=n;i>0;i--)d+=`A${a},${a},0,0,0,0,${(i-1)*s} `;return d+'Z';}if(id==='stamp'){let d=`M0,0H${W} `;for(let i=0;i<n;i++)d+=`A${a},${a},0,0,1,${W},${(i+1)*s} `;d+=`H0 `;for(let i=n;i>0;i--)d+=`A${a},${a},0,0,1,0,${(i-1)*s} `;return d+'Z';}return`M0,0H${W}V${H}H0Z`;}
