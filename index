const IPS=[{id:'none',n:'없음'},{id:'left',n:'왼쪽'},{id:'right',n:'오른쪽'},{id:'top',n:'상단'},{id:'bottom',n:'하단'},{id:'bg',n:'배경'},{id:'center',n:'중앙'},{id:'full',n:'전체'}];
