function getTargetHTML(target) {
  const f = buildTicket('front');
  const b = buildTicket('back');
  let content = '';
  if (target === 'all' || target === 'front') {
    content += `<div style="text-align:center;"><div style="font-size:11px;color:#888;margin-bottom:6px;">앞면</div>${f}</div>`;
