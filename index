}

function dl(n,b){const a=document.createElement('a');a.href=URL.createObjectURL(b);a.download=n;a.click();}

document.getElementById('dHA').addEventListener('click', () => {
  const target = document.getElementById('expTarget').value;
  dl(`ticket_${target}.html`, new Blob([mkH(target)],{type:'text/html;charset=utf-8'}));
});

document.getElementById('cpBlog').addEventListener('click', () => {
  const target = document.getElementById('expTarget').value;
  const content = getTargetHTML(target);
  const html = `<style>${fontImports}</style><div style="display:flex;flex-wrap:wrap;gap:20px;justify-content:center;padding:16px;">${content}</div>`;
  
  navigator.clipboard.writeText(html).then(() => {
    const btn = document.getElementById('cpBlog');
    btn.textContent = '✅';
    setTimeout(() => btn.textContent = '📝블로그복사', 1500);
  });
});

function dP(side) {
  const el = document.createElement('div');
  el.style.cssText = 'position:absolute; left:-9999px; top:-9999px;';
  el.innerHTML = buildTicket(side);
  document.body.appendChild(el);
  
  const ticket = el.firstElementChild;
  
  html2canvas(ticket, {
    backgroundColor: null,
    scale: 3,
    useCORS: true
  }).then(canvas => {
    canvas.toBlob(blob => {
      dl(`ticket-${side}.png`, blob);
      document.body.removeChild(el);
    }, 'image/png');
  }).catch(err => {
    console.error('PNG 캡처 에러:', err);
    alert('PNG 저장 중 오류가 발생했습니다.');
    document.body.removeChild(el);
  });
}

document.getElementById('dPNG').addEventListener('click', () => {
  const target = document.getElementById('expTarget').value;
  if (target === 'all') {
    dP('front');
    setTimeout(() => dP('back'), 500);
  } else {
    dP(target);
  }
});

render();
</script>
