<div><div class="sc">바코드</div>
<div class="sg" id="sgBC"><button class="on" data-v="barcode">바코드</button><button data-v="none">없음</button></div>
<div id="bdRow" style="margin-top:3px;"><label style="font-size:.64rem;color:var(--mt);">밀도 <span id="dVal">20</span></label><input type="range" id="bDen" min="8" max="60" step="2" value="20"></div></div>
<hr class="dv">
<div><div class="sc">장식</div>
<label class="tog"><input type="checkbox" id="decDots" checked><span class="t"></span>도트라인</label>
<label class="tog" style="margin-top:2px;"><input type="checkbox" id="decBorder" checked><span class="t"></span>내부 테두리</label></div>
<hr class="dv">
<div><div class="sc">작업 환경</div>
<div style="margin-bottom:2px;"><label style="font-size:.62rem;color:var(--mt);">UI</label>
<div class="sg" id="sgMode"><button class="on" data-v="light">☀️밝게</button><button data-v="dark">🌙어둡게</button></div></div>
<div><label style="font-size:.62rem;color:var(--mt);">배경</label>
<div class="sg" id="sgBg"><button class="on" data-v="cl">체크밝게</button><button data-v="cd">체크어둡게</button><button data-v="w">흰색</button><button data-v="b">검정</button></div></div></div>
</div>

<div class="pg" data-t="front">
<div><div class="sc">메인 제목</div>
<div class="f"><input type="text" id="fT" placeholder="제목을 입력하세요"></div>
<div class="rw" style="margin-top:2px;"><div class="f"><label>폰트</label><select id="fnT"></select></div><div class="sz" style="width:42px;"><label>크기</label><input type="number" id="tsz" value="0" min="0" max="120" placeholder="자동"></div></div>
<div class="sr" style="margin-top:2px;"><button class="sb2 fb" data-f="tB">B</button><button class="sb2 fi" data-f="tI">I</button><button class="sb2 fu" data-f="tU">U</button><button class="sb2 fs" data-f="tS">S</button></div>
<div style="margin-top:2px;">
<label class="tog"><input type="checkbox" id="titleGrad"><span class="t"></span>글씨 그라데이션</label>
<div id="titleGradOpts" style="display:none;margin-top:2px;">
<div class="cr"><span>끝색상</span><input type="color" id="titleGrad2" value="#d4a830"></div>
<div class="sg" id="sgTGDir" style="margin-top:2px;"><button class="on" data-v="135deg">↘</button><button data-v="90deg">↓</button><button data-v="0deg">→</button></div>
</div>
</div>
</div>
<div><div class="sc">부제목</div>
<div class="f"><input type="text" id="fSb" placeholder="부제목"></div>
<div class="rw" style="margin-top:2px;"><div class="f"><label>폰트</label><select id="fnS"></select></div><div class="sz" style="width:42px;"><label>크기</label><input type="number" id="ssz" value="11" min="5" max="40"></div></div></div>
<div><div class="sc">날짜 · 장소</div>
<div class="fr"><div class="f"><input type="text" id="fDt" placeholder="날짜"></div><div class="sz"><input type="number" id="dSz" value="9" min="5" max="28"></div></div>
<div class="fr" style="margin-top:2px;"><div class="f"><input type="text" id="fVn" placeholder="장소"></div><div class="sz"><input type="number" id="vSz" value="10" min="5" max="28"></div></div></div>
<hr class="dv">
<div><div class="sc">위치 미세조정 (X / Y)</div>
<div class="rw" style="margin-bottom:2px;"><div class="f" style="flex:0.5"><label>제목</label></div><div class="f"><input type="number" id="fT_x" value="0" step="1"></div><div class="f"><input type="number" id="fT_y" value="0" step="1"></div></div>
<div class="rw" style="margin-bottom:2px;"><div class="f" style="flex:0.5"><label>부제목</label></div><div class="f"><input type="number" id="fS_x" value="0" step="1"></div><div class="f"><input type="number" id="fS_y" value="0" step="1"></div></div>
<div class="rw"><div class="f" style="flex:0.5"><label>내용</label></div><div class="f"><input type="number" id="fD_x" value="0" step="1"></div><div class="f"><input type="number" id="fD_y" value="0" step="1"></div></div>
</div>
<hr class="dv">
<div><div class="sc">절취 구역</div>
<div class="fr"><div class="f"><label>티켓번호</label><input type="text" id="bCd" placeholder="TK-0000-00000"></div><div class="sz"><input type="number" id="cdSz" value="7" min="4" max="16" step=".5"></div></div>
<div class="fr" style="margin-top:2px;"><div class="f"><label>바코드텍스트</label><input type="text" id="bcTx" placeholder="ADMIT ONE"></div><div class="sz"><input type="number" id="bcSz" value="7.5" min="4" max="16" step=".5"></div></div></div>
<hr class="dv">
<div><div class="sc">앞면 이미지</div>
