bID:'',bIU:'',bIP:'none',bIOp:100,bIRd:4,bIOx:0,bIOy:0, bTxOx:0, bTxOy:0, bFdOn:false,bFdDir:'right',bFdR:40,bFdCol:'',bFdTr:false,
decDots:true,decBorder:true};

function gt(){return TH.find(t=>t.id===S.theme)||TH[0];}

function clipPath(W,H,edge){
  const pct=(x,y)=>`${(x/W*100).toFixed(2)}% ${(y/H*100).toFixed(2)}%`;
  if(edge==='round')return'inset(0 round 14px)';
  if(edge==='roundXL')return'inset(0 round 32px)';
  if(edge==='straight')return'none';
  if(edge==='chamfer'){const c=18;return`polygon(${pct(c,0)},${pct(W-c,0)},${pct(W,c)},${pct(W,H-c)},${pct(W-c,H)},${pct(c,H)},${pct(0,H-c)},${pct(0,c)})`;}
  let pts=[];
  if(edge==='zigS'||edge==='zigL'){
    const n=edge==='zigS'?12:7, a=edge==='zigS'?6:12, sH=H/n;
    pts.push(pct(0,0));pts.push(pct(W,0));
    for(let i=0;i<n;i++){pts.push(pct(W-a,i*sH+sH/2));pts.push(pct(W,(i+1)*sH));}
    pts.push(pct(0,H));
    for(let i=n;i>0;i--){pts.push(pct(a,(i-1)*sH+sH/2));pts.push(pct(0,(i-1)*sH));}
    return`polygon(${pts.join(',')})`;
  }
  if(edge==='zigSH'||edge==='zigLH'){
    const n=edge==='zigSH'?14:8, a=edge==='zigSH'?6:12, sW=W/n;
    pts.push(pct(0,0));
    for(let i=0;i<n;i++){pts.push(pct(i*sW+sW/2,a));pts.push(pct((i+1)*sW,0));}
    pts.push(pct(W,H));
    for(let i=n;i>0;i--){pts.push(pct((i-1)*sW+sW/2,H-a));pts.push(pct((i-1)*sW,H));}
    return`polygon(${pts.join(',')})`;
  }
  if(edge.startsWith('wave')){
    const n=edge==='waveS'?10:5, a=edge==='waveS'?5:12, sH=H/n, steps=4;
    pts.push(pct(0,0));pts.push(pct(W,0));
    for(let i=0;i<n;i++){for(let j=1;j<=steps;j++){const t=j/steps,y=i*sH+t*sH;pts.push(pct(W-Math.sin(t*Math.PI)*a,y));}}
    pts.push(pct(0,H));
    for(let i=n;i>0;i--){for(let j=1;j<=steps;j++){const t=j/steps,y=i*sH-t*sH;pts.push(pct(Math.sin(t*Math.PI)*a,y));}}
    return`polygon(${pts.join(',')})`;
  }
  if(edge==='scallop'||edge==='stamp'){
    const n=8,r=8,sH=H/n,dir=edge==='scallop'?1:-1;
    pts.push(pct(0,0));pts.push(pct(W,0));
    for(let i=0;i<n;i++){const cy=(i+.5)*sH;pts.push(pct(W+dir*r*.3,i*sH+sH*.2));pts.push(pct(W+dir*r,cy));pts.push(pct(W+dir*r*.3,i*sH+sH*.8));pts.push(pct(W,(i+1)*sH));}
    pts.push(pct(0,H));
    for(let i=n;i>0;i--){const cy=(i-.5)*sH;pts.push(pct(-dir*r*.3,i*sH-sH*.2));pts.push(pct(-dir*r,cy));pts.push(pct(-dir*r*.3,i*sH-sH*.8));pts.push(pct(0,(i-1)*sH));}
    return`polygon(${pts.join(',')})`;
  }
  return'none';
}

function buildTicket(side){
  const th=gt();
  const W=Math.max(150,S.tW),H=Math.max(80,S.tH),stub=Math.max(40,Math.min(S.tS,Math.floor(W*.4)));
  const isL=S.orient==='landscape';
  const mainW=isL?W-stub:W, mainH=isL?H:H-stub;
  const ac=S.cAc,tx=S.cTx,sb=S.cSb,bg=S.cBg;
  const clip=clipPath(W,H,S.edge);
  const tFont=S.fnT||th.f1, sFont=S.fnS||th.f2;
  const titleDisp=ph(S.fT,'제목을 입력하세요');
  const phColor='#bbb';
  let ts=S.tsz>0?S.tsz:Math.min(48,Math.max(14,isL?(mainW-80)/Math.max((S.fT||'제목').length,3)*1.4:(mainW-20)/Math.max((S.fT||'제목').length,3)*2));
  const ss=S.ssz||11;
  const bgCss=S.bgGrad?`linear-gradient(${S.bgGradDir},${S.cBg},${S.bgGrad2})`:S.cBg;
  let stripStyle='';
  if(S.stOn&&S.stPos.length){
    const sw=S.stW+'px';
    const sides={top:'border-top',right:'border-right',bottom:'border-bottom',left:'border-left'};
    S.stPos.forEach(p=>{if(sides[p])stripStyle+=`${sides[p]}:${sw} solid ${ac};`;});
  }
  const perfStyle=isL
    ?`position:absolute;top:0;bottom:0;right:${stub}px;width:0;border-right:2px dashed rgba(${hexRgb(tx)},.2);z-index:5;`
    :`position:absolute;left:0;right:0;bottom:${stub}px;height:0;border-bottom:2px dashed rgba(${hexRgb(tx)},.2);z-index:5;`;
  const innerBorder=S.decBorder?`border:1px solid rgba(${hexRgb(ac)},.25);border-radius:${S.edge==='round'?'10px':S.edge==='roundXL'?'26px':'0'};margin:8px;`:'margin:8px;';
  
  let barcodeSvg='';
  if(S.bcSt==='barcode'){
    const n=S.bDen||20,seed=S.bCd||'TK';
    const bars=[];for(let i=0;i<n;i++)bars.push((seed.charCodeAt(i%seed.length)%3)+1);
    const tot=bars.reduce((a,b)=>a+b,0);
    if(isL){
      const bH=mainH-36,bW=stub-24;
      let rects='',cy=0,u=bH/tot;
      bars.forEach((bw,i)=>{if(i%2===0)rects+=`<rect x="0" y="${cy.toFixed(1)}" width="${bW}" height="${Math.max(.5,(bw*u-.3)).toFixed(1)}" fill="${tx}" opacity=".8"/>`;cy+=bw*u;});
      barcodeSvg=`<svg width="${bW}" height="${bH}" style="display:block;margin:auto;">${rects}</svg>`;
    }else{
      const bW=mainW-20,bH=stub-20;
      let rects='',cx=0,u=bW/tot;
      bars.forEach((bw,i)=>{if(i%2===0)rects+=`<rect x="${cx.toFixed(1)}" y="0" width="${Math.max(.5,(bw*u-.3)).toFixed(1)}" height="${bH}" fill="${tx}" opacity=".8"/>`;cx+=bw*u;});
      barcodeSvg=`<svg width="${bW}" height="${bH}" style="display:block;margin:auto;">${rects}</svg>`;
    }
  }

  const dotLine=S.decDots?`<div style="height:3px;background:repeating-linear-gradient(to right,rgba(${hexRgb(tx)},.3) 0 2px,transparent 2px 8px);margin:4px 0;"></div>`:'';

  function imgDiv(imgSrc,pos,op,rd,ox,oy,fdOn,fdDir,fdR,fdCol,fdTr,mW2,mH2){
    if(!imgSrc||pos==='none')return'';
    const a=op/100;
    const fadeMask=fdOn?(()=>{
      const dirs={right:'to right',left:'to left',down:'to bottom',up:'to top'};
      const d=dirs[fdDir]||'to right';
      return`linear-gradient(${d},black ${100-fdR}%,transparent 100%)`;
    })():'';
    const maskStyle=fdOn?`mask-image:${fadeMask};-webkit-mask-image:${fadeMask};`:'';
    const fadeOverlay=(fdOn&&!fdTr&&fdCol)?(()=>{
      const dirs={right:'to left',left:'to right',down:'to top',up:'to bottom'};
      const d=dirs[fdDir]||'to left';
      return`<div style="position:absolute;inset:0;background:linear-gradient(${d},transparent ${100-fdR}%,${fdCol} 100%);pointer-events:none;z-index:2;"></div>`;
    })():'';
    const base=`background:url('${imgSrc}') center/cover no-repeat;opacity:${a};border-radius:${rd}px;${maskStyle}`;
    const offX=ox||0, offY=oy||0;
    if(pos==='bg')return`<div style="position:absolute;inset:0;transform:translate(${offX}px,${offY}px);${base}z-index:0;"></div>${fadeOverlay}`;
    if(pos==='full')return`<div style="position:absolute;inset:0;transform:translate(${offX}px,${offY}px);${base}z-index:0;"></div><div style="position:absolute;inset:0;background:${bg};opacity:.45;z-index:1;"></div>${fadeOverlay}`;
    if(pos==='left'){const iw=Math.floor(mH2*.7);return`<div style="position:absolute;left:${6+offX}px;top:${6+offY}px;bottom:6px;width:${iw}px;${base}z-index:1;"></div>${fadeOverlay}`;}
    if(pos==='right'){const iw=Math.floor(mH2*.65);return`<div style="position:absolute;right:${6-offX}px;top:${6+offY}px;bottom:6px;width:${iw}px;${base}z-index:1;"></div>${fadeOverlay}`;}
    if(pos==='top'){const ih=Math.floor(mH2*.45);const defMask=`mask-image:linear-gradient(to bottom,black 55%,transparent);-webkit-mask-image:linear-gradient(to bottom,black 55%,transparent);`;return`<div style="position:absolute;left:0;right:0;top:${offY}px;height:${ih}px;${base}${fdOn?'':defMask}z-index:1;"></div>${fadeOverlay}`;}
    if(pos==='bottom'){const ih=Math.floor(mH2*.4);const defMask=`mask-image:linear-gradient(to top,black 55%,transparent);-webkit-mask-image:linear-gradient(to top,black 55%,transparent);`;return`<div style="position:absolute;left:0;right:0;bottom:${-offY}px;height:${ih}px;${base}${fdOn?'':defMask}z-index:1;"></div>${fadeOverlay}`;}
    if(pos==='center'){const sz=Math.min(mW2,mH2)*.45;return`<div style="position:absolute;left:50%;top:50%;transform:translate(calc(-50% + ${offX}px),calc(-50% + ${offY}px));width:${sz}px;height:${sz}px;${base}border-radius:50%;z-index:1;"></div>${fadeOverlay}`;}
    return'';
  }

  const fImg=S.fID||S.fIU||'';
  const imgHtml=imgDiv(fImg,S.fIP,S.fIOp,S.fIRd,S.fIOx,S.fIOy,S.fFdOn,S.fFdDir,S.fFdR,S.fFdCol||bg,S.fFdTr,mainW,mainH);
  const contentML=fImg&&S.fIP==='left'?Math.floor(mainH*.7)+12:0;
  const contentMR=fImg&&S.fIP==='right'?Math.floor(mainH*.65)+12:0;

  const bImg=S.bID||S.bIU||'';
  const bImgHtml=imgDiv(bImg,S.bIP,S.bIOp,S.bIRd||4,S.bIOx,S.bIOy,S.bFdOn,S.bFdDir,S.bFdR,S.bFdCol||bg,S.bFdTr,mainW,mainH);

  const titleColorStyle=S.titleGrad?`background:linear-gradient(${S.titleGradDir},${tx},${S.titleGrad2});-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;`:`color:${tx};`;

  // ✨ 제목, 부제목, 날짜/장소가 완전히 독립된 블록으로 나뉘어 개별적으로 위치 이동이 적용됩니다!
  const subDisp=ph(S.fSb,'부제목');
  const dtDisp=ph(S.fDt,'날짜');
  const vnDisp=ph(S.fVn,'장소');
  const align = S.tAl || 'center'; 

  let frontContent=`
    ${imgHtml}
    <div style="position:relative;z-index:2;${innerBorder}display:flex;flex-direction:column;justify-content:center;height:100%;padding:${isL?'8px 12px':'12px 8px'};margin-left:${contentML}px;margin-right:${contentMR}px;">
      ${dotLine}
      <div style="display:flex; flex-direction:column; gap:8px; padding:${isL?'8px 0':'12px 0'};">
        <div style="text-align:${align}; transform:translate(${S.fT_x||0}px, ${S.fT_y||0}px);">
          <div style="font-family:${tFont};font-size:${ts}px;font-weight:${S.tB?700:(tFont.includes('Bebas')?400:700)};${S.tI?'font-style:italic;':''}${S.tU?'text-decoration:underline;':''}${S.tS2?'text-decoration:line-through;':''}${titleDisp.ph?'color:'+phColor+';':titleColorStyle}line-height:1.2;">${titleDisp.t}</div>
        </div>
        <div style="text-align:${align}; transform:translate(${S.fS_x||0}px, ${S.fS_y||0}px);">
